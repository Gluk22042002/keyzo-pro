{
  "name": "keyzo-pro",
  "version": "1.0.0",
  "description": "Keyzo.pro — Маркетплейс цифровых товаров",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "test": "node --test server/*.test.js 2>/dev/null || echo 'No test files found'",
    "migrate": "node server/migrate.js",
    "migrate:auto": "node server/migrate_auto.js",
    "migrate:rollback": "node server/migrate_auto.js rollback",
    "migrate:status": "node server/migrate_auto.js status",
    "seed": "node server/seed.js",
    "seed:large": "node server/seed_large.js",
    "seed:demo": "node server/seed_demo.js",
    "setup": "bash scripts/setup.sh",
    "setup:demo": "bash scripts/setup.sh --demo",
    "setup:large": "bash scripts/setup.sh --large",
    "backup": "bash scripts/backup.sh"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.10",
    "otpauth": "^9.5.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "bullmq": "^5.77.6",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.0",
    "jest": "^30.4.2",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.0",
    "winston": "^3.19.0"
  }
}
