# ============================================
# Keyzo.pro — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# === Server ===
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# === Database (PostgreSQL) ===
DATABASE_URL=postgresql://keyzo:your_password@localhost:5432/keyzo_pro
POSTGRES_USER=keyzo
POSTGRES_PASSWORD=your_password
POSTGRES_DB=keyzo_pro
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === Security ===
JWT_SECRET=your-super-secret-random-string-here-change-me
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# === Email (SMTP) — Optional ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@keyzo.pro

# === Upload ===
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./public/uploads

# === Rate Limiting ===
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200

# === CORS ===
CORS_ORIGIN=*

# === App Info ===
APP_NAME=Keyzo.pro
APP_VERSION=1.0.0
APP_URL=http://localhost:3001

# === Redis ===
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# === Queue (BullMQ) ===
QUEUE_CONCURRENCY=5
QUEUE_MAX_RETRIES=3
QUEUE_DELAY_BETWEEN_JOBS=1000

# === Logging ===
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# === Backup ===
BACKUP_DIR=./backups
BACKUP_KEEP_COUNT=7

# === OAuth (Optional) ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=

# === Deploy (Optional) ===
DEPLOY_HOST=
DEPLOY_USER=
SSH_PRIVATE_KEY=
